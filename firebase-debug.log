[debug] [2026-03-02T10:21:34.075Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/glooprvm/rulesets {"name":"projects/glooprvm/rulesets/5c98f3be-b406-49fb-9feb-5befbd9a7166","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /machines/{machineId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth != null && (\n        // First claim when machine has no current user.\n        (!exists(/databases/$(database)/documents/machines/$(machineId)) &&\n          request.resource.data.current_user == request.auth.uid) ||\n        // Claim machine when it is currently unassigned.\n        (resource.data.current_user == \"\" &&\n          request.resource.data.current_user == request.auth.uid) ||\n        // Active owner can keep updating machine state.\n        resource.data.current_user == request.auth.uid\n      );\n    }\n\n    match /users/{userId} {\n      allow read, write: if request.auth != null && request.auth.uid == userId;\n    }\n\n    match /users/{userId}/sessions/{sessionId} {\n      allow read, write: if request.auth != null && request.auth.uid == userId;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-02T10:21:33.856559Z","metadata":{"services":["cloud.firestore"]}}
