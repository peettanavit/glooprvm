# Path to your Firebase service account JSON (download from Firebase Console →
# Project Settings → Service Accounts → Generate new private key)
FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json

# Firebase Storage bucket name (found in Firebase Console → Storage)
FIREBASE_STORAGE_BUCKET=glooprvm.firebasestorage.app

# Same API key the ESP32 sends in the X-Api-Key header
# Must match CF_UPLOAD_API_KEY in esp32/config.h
UPLOAD_API_KEY=5a6142e104cbe23db7617cf4a201ac4f7a31dc11dae47500fa2f1219ad390bd4

# Server port (default: 5000)
PORT=5000

# Minimum YOLO confidence to accept or reject a detection (0.0–1.0, default: 0.5)
# Lower = more permissive. Raise to 0.6–0.7 if you get false positives.
AI_CONFIDENCE_THRESHOLD=0.5

# Safety Lock floor (default: 0.35)
# If label_model top confidence is below this value, the bottle is REJECTED
# immediately with reason="Low confidence" — no class-level logic runs.
# Must be lower than AI_CONFIDENCE_THRESHOLD.
AI_SAFETY_LOCK_THRESHOLD=0.35

# Seconds listener.py waits for the Slave ESP32 (cap camera) to upload its image
# after the Master triggers. If Slave doesn't arrive in time, falls back to
# single-cam mode (label model only). Default: 2.0
CAP_WAIT_SECONDS=1.5
