rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /machines/{machineId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        // First claim when machine has no current user.
        (!exists(/databases/$(database)/documents/machines/$(machineId)) &&
          request.resource.data.current_user == request.auth.uid) ||
        // Claim machine when it is currently unassigned.
        (resource.data.current_user == "" &&
          request.resource.data.current_user == request.auth.uid) ||
        // Active owner can keep updating machine state.
        resource.data.current_user == request.auth.uid
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
