rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isActiveStatus(status) {
      return status in ['READY', 'PROCESSING', 'REJECTED'];
    }

    function isMachineClient() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('^machine-.*@.*$');
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /machines/{machineId} {
      allow read: if isSignedIn();

      // First claim must bind machine ownership to the signed-in user (score starts at 0).
      allow create: if isSignedIn()
        && request.resource.data.current_user == request.auth.uid
        && request.resource.data.session_score == 0;

      allow update: if isSignedIn() && (
        // Active owner can update machine state but cannot inflate session_score.
        (resource.data.current_user == request.auth.uid
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['session_score'])
              || request.resource.data.session_score == 0))
        ||
        // Claim unassigned machine (score must start at 0).
        (resource.data.current_user == ""
          && request.resource.data.current_user == request.auth.uid
          && request.resource.data.session_score == 0)
        ||
        // Reclaim machine from stale inactive state (IDLE/COMPLETED, score must start at 0).
        (!isActiveStatus(resource.data.status)
          && request.resource.data.current_user == request.auth.uid
          && request.resource.data.session_score == 0)
        ||
        // Machine device account can only update runtime machine state fields.
        (isMachineClient()
          && request.resource.data.current_user == resource.data.current_user
          && request.resource.data.session_id == resource.data.session_id
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'session_score'
          ]))
        ||
        // Active session owner performing a slot event (bottle physically confirmed).
        (resource.data.current_user == request.auth.uid
          && isActiveStatus(resource.data.status)
          && request.resource.data.status == 'READY'
          && request.resource.data.current_user == resource.data.current_user
          && request.resource.data.session_id == resource.data.session_id
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'session_score', 'slotCounts', 'lastSlotEvent', 'updatedAt'
          ]))
      );
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/sessions/{sessionId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/redemptions/{redemptionId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /logs/{logId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.user_id || isAdmin());
      allow write: if false; // written only by Cloud Functions via Admin SDK
    }

    // Admin role: documents created manually via Firebase console
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
